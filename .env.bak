MYTAX_API_URL=
MYTAX_API_TOKEN=
MYTAX_SELLER_INN=
FISCAL_RETRY_INTERVAL_SECONDS=300
FISCAL_MAX_ATTEMPTS=5
PAYMENT_SIDE_EFFECT_RETRY_INTERVAL_SECONDS=120
REFERRAL_BONUS_REQUESTS=2
ANTIFLOOD_WINDOW_SECONDS=10
