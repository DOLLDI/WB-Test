# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ============================================
# VK BOT
# ============================================
VK_GROUP_TOKEN=YOUR_VK_GROUP_TOKEN_HERE
VK_CONFIRMATION_TOKEN=YOUR_VK_CONFIRMATION_TOKEN_HERE
VK_GROUP_ID=
VK_CALLBACK_SECRET=
VK_AUTO_SET_CALLBACK=true
VK_CALLBACK_SERVER_TITLE=ProxyApiBots

# ============================================
# PROXY API (ИИ BACKEND)
# ============================================
PROXYAPI_URL=https://api.proxyapi.ru/openai/v1
PROXYAPI_KEY=YOUR_PROXYAPI_KEY_HERE

# ============================================
# ADMIN SETTINGS
# ============================================
ADMIN_TOKEN=supersecret123456789
ADMIN_IDS=123456789,987654321

# ============================================
# DATABASE (выбрать один из вариантов)
# ============================================
DB_BACKEND=sqlite
# DB_BACKEND=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/proxyapi
SQLITE_DB_PATH=users.db

# ============================================
# LOGGING
# ============================================
ERROR_LOG_PATH=proxyapi_errors.log

# ============================================
# APP CONFIGURATION
# ============================================
APP_BASE_URL=http://localhost:8000
PUBLIC_WEBHOOK_BASE_URL=
AUTO_SET_WEBHOOKS=true
AUTO_SET_TELEGRAM_WEBHOOK=false
TELEGRAM_DELIVERY_MODE=webhook
START_CLOUDFLARED=true
CLOUDFLARED_METRICS_URL=http://127.0.0.1:4040/metrics
TUNNEL_WAIT_SECONDS=120

# ============================================
# BILLING CONFIGURATION
# ============================================
PAYMENT_PROVIDER=sandbox
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:8000/billing/return
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_MODE=true
BILLING_SECRET=change-me-billing-secret

# ============================================
# FISCAL (RECEIPT) INTEGRATION (OPTIONAL)
# ============================================
MYTAX_API_URL=
MYTAX_API_TOKEN=
MYTAX_SELLER_INN=
FISCAL_RETRY_INTERVAL_SECONDS=300
FISCAL_MAX_ATTEMPTS=5

# ============================================
# PAYMENT WORKERS
# ============================================
PAYMENT_SIDE_EFFECT_RETRY_INTERVAL_SECONDS=120

# ============================================
# RATE LIMITING & ANTIFLOOD
# ============================================
ANTIFLOOD_WINDOW_SECONDS=10
ANTIFLOOD_MAX_REQUESTS=3

# ============================================
# REFERRAL SYSTEM
# ============================================
REFERRAL_BONUS_REQUESTS=2

# ============================================
# AI PROMPTS (OPTIONAL)
# ============================================
TELEGRAM_SYSTEM_PROMPT=
VK_SYSTEM_PROMPT=
WB_SUMMARY_PROMPT=

# ============================================
# WB PARSER CONFIGURATION
# ============================================
WB_PROXY_URL=
WB_ENABLE_ROTATING_PROXIES=false
